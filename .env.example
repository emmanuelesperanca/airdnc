# ============================================================
#  AirDnC – Variáveis de ambiente
#  Copie para .env e preencha os valores reais.
#  O arquivo .env está no .gitignore — NUNCA o commite.
# ============================================================

# Segredo para assinar os tokens JWT (gere com: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=GERE_UM_SEGREDO_ALEATORIO_DE_32_CHARS_AQUI

# URL pública do app AirDnC (usada para montar o magic link)
AIRDNC_BASE_URL=https://airdnc.straumann.com

# Segredo compartilhado entre o Power Automate e a API (header X-PA-Secret)
PA_CALLBACK_SECRET=DEFINA_UM_SEGREDO_COMPARTILHADO_COM_O_PA

# Domínios de e-mail corporativo permitidos (separados por vírgula)
ALLOWED_DOMAINS=straumann.com

# Validade do magic link em minutos (padrão: 10)
TOKEN_TTL_MINUTES=10

# Porta da API
PORT=5000

# Origins permitidas no CORS (use a URL do app em produção)
CORS_ORIGINS=https://airdnc.straumann.com

# ── Banco de dados SQL Server ─────────────────────────────────
# Deixe DB_HOST em branco para rodar sem banco (modo localStorage only)
DB_HOST=sql-latam.straumann.com
DB_NAME=rpa_area_finance_internal_P
DB_SCHEMA=tech_solutions
DB_USER=SEU_USUARIO_SQL
DB_PASS=SUA_SENHA_SQL
DB_DRIVER=ODBC Driver 18 for SQL Server


# Origens CORS permitidas (use * apenas em desenvolvimento)
CORS_ORIGINS=*

# ── Banco de dados SQL Server (opcional — para persistir auditoria) ──
# Configure via Azure Key Vault em produção
DB_HOST=sql-latam.straumann.com
DB_NAME=SEU_BANCO_AQUI
DB_USER=SEU_USUARIO_AQUI
DB_PASS=SUA_SENHA_AQUI
